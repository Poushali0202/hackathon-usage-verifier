# Template — copy to `.env` for local runs. NEVER put real values here (this file is committed).
# On Render, set these in the dashboard (Environment → Environment Variables), not in a file.
#
# Locally, ROCKETRIDE_URI and ROCKETRIDE_APIKEY may be auto-synced by the RocketRide VS Code
# extension. On Render there is no extension, so set all four explicitly.

ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=rr_your_api_key_here
ROCKETRIDE_ANTHROPIC_KEY=sk-ant-your-funded-anthropic-key
# Needed for large batches — parallel repos hit GitHub's 60-req/hr unauthenticated limit fast:
ROCKETRIDE_GITHUB_TOKEN=github_pat_your_token
